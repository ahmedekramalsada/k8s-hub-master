# K8s Hub — Environment Variables
# Copy to .env and fill in values
# For Docker: cp .env.example .env

# ── Server ──
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=production

# ── AI (get key at openrouter.ai — leave empty to disable) ──
OPENROUTER_API_KEY=

# ── Docker Compose ──
FRONTEND_PORT=8080

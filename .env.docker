# ==========================================
# K8s Hub — Docker Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.docker .env
#   docker-compose up

# ── Ports ──────────────────────────────────
# Change if default ports conflict with other services
FRONTEND_PORT=8080
BACKEND_PORT=3001

# ── Frontend URL ───────────────────────────
# URL where users will access the app
# For local: http://localhost:8080
# For production: https://k8s-hub.yourdomain.com
FRONTEND_URL=http://localhost:8080

# ── AI Configuration ──────────────────────
# Get a free API key at https://openrouter.ai
# Leave empty to disable AI features
OPENROUTER_API_KEY=
